// Copy this file to Secrets.swift and fill in your values.
// Secrets.swift is gitignored and will not be committed.

import Foundation

enum Secrets {
  // REQUIRED: Get your key at https://console.x.ai
  // Leave empty if you use the Grok auth broker below.
  static let grokAPIKey = "YOUR_GROK_API_KEY"

  // OPTIONAL: Host-side Grok OAuth broker (for personal builds using xAI OAuth)
  // The sample WebRTC server exposes this at /api/grok/token when configured.
  static let grokAuthBrokerURL = "https://YOUR_HOST/api/grok/token"
  static let grokAuthBrokerToken = "YOUR_GROK_AUTH_BROKER_TOKEN"

  // OPTIONAL: OpenClaw gateway config (for agentic tool-calling)
  // Use your Mac's Bonjour hostname (run: scutil --get LocalHostName)
  static let openClawHost = "http://YOUR_MAC_HOSTNAME.local"
  static let openClawPort = 18789
  static let openClawHookToken = "YOUR_OPENCLAW_HOOK_TOKEN"
  static let openClawGatewayToken = "YOUR_OPENCLAW_GATEWAY_TOKEN"

  // OPTIONAL: WebRTC signaling server URL (for live POV streaming)
  // Run: cd samples/CameraAccess/server && npm install && npm start
  static let webrtcSignalingURL = "ws://YOUR_MAC_IP:8080"

  // OPTIONAL: Picovoice Porcupine wake word
  // Get an AccessKey at https://console.picovoice.ai
  static let porcupineAccessKey = "YOUR_PICOVOICE_ACCESS_KEY"
}
