package com.meta.wearable.dat.externalsampleapps.cameraaccess

object Secrets {
    // REQUIRED: Get your key at https://console.x.ai
    // Leave empty if you use the Grok auth broker below.
    const val grokAPIKey = "YOUR_GROK_API_KEY"

    // OPTIONAL: Host-side Grok OAuth broker (for personal builds using xAI OAuth)
    // The sample WebRTC server exposes this at /api/grok/token when configured.
    const val grokAuthBrokerURL = "https://YOUR_HOST/api/grok/token"
    const val grokAuthBrokerToken = "YOUR_GROK_AUTH_BROKER_TOKEN"

    // OPTIONAL: OpenClaw gateway config (for agentic tool-calling)
    // Use your Mac's Bonjour hostname (run: scutil --get LocalHostName)
    const val openClawHost = "http://YOUR_MAC_HOSTNAME.local"
    const val openClawPort = 18789
    const val openClawHookToken = "YOUR_OPENCLAW_HOOK_TOKEN"
    const val openClawGatewayToken = "YOUR_OPENCLAW_GATEWAY_TOKEN"

    // OPTIONAL: WebRTC signaling server URL (for live POV streaming)
    const val webrtcSignalingURL = "wss://YOUR_SIGNALING_SERVER"

    // OPTIONAL: Picovoice Porcupine wake word
    // Get an AccessKey at https://console.picovoice.ai
    const val porcupineAccessKey = "YOUR_PICOVOICE_ACCESS_KEY"
}
